    "build": "cross-env REGION=cn npm run build:prod",
    "build:prod": "rsbuild build",
    "build:ts": "tsc -b tsconfig.build.json",
    "dev": "npm run dev:cn-boe",
    "dev:base": "rsbuild dev",
    "dev:cn": "cross-env REGION=cn npm run dev",
    "dev:cn-boe": "cross-env REGION=cn CUSTOM_VERSION=inhouse BUILD_TYPE=offline npm run dev:base",
    "dev:cn-release": "cross-env REGION=cn CUSTOM_VERSION=release BUILD_TYPE=online npm run dev:base",
    "lint": "eslint ./ --cache --quiet",
    "preview": "rsbuild preview",
    "test": "vitest --run --passWithNoTests",
    "why": "rush-pnpm --subspace default why"
  },
